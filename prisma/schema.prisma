generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Schools {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  email    String     @unique
  phone    Int
  motto    String
  vision   String
  exams    Exams[]
  students Students[]
  subjects Subjects[]
  teachers Teachers[]
  users    User[]
}

model Teachers {
  id        Int      @id @default(autoincrement())
  name      String
  gender    String
  email     String   @unique
  phone     Int
  schoolId  Int
  createdAt DateTime @default(now())
  school    Schools  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Students {
  id        Int       @id @default(autoincrement())
  name      String
  gender    String
  dob       DateTime
  schoolId  Int
  grade     String
  createdAt DateTime  @default(now())
  results   Results[]
  school    Schools   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Subjects {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  schoolId  Int
  results   Results[]
  school    Schools   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Exams {
  id       Int       @id @default(autoincrement())
  exam     String
  term     String
  year     DateTime  @default(now())
  schoolId Int
  school   Schools   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  results  Results[]
}

model Results {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  examId    Int
  score     Int
  exam      Exams    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   Students @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subjects @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model User {
  id          Int     @id @default(autoincrement())
  name        String
  email       String  @unique
  password    String
  role        String
  referenceId String?
  schoolId    Int
  school      Schools @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}
